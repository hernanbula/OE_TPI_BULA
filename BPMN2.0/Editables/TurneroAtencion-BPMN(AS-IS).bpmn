    <participant id="Participant_1qiy69l" name="Centro Médico Integral: Proceso de Recepción (AS-IS)" processRef="Process_1ax25qj" />
    <textAnnotation id="TextAnnotation_0jisrq7">
      <text>Proceso dependiente de intervención humana</text>
    </textAnnotation>
    <textAnnotation id="TextAnnotation_1g9zmme">
      <text>Información cargada y actualizada manualmente.</text>
    </textAnnotation>
    <textAnnotation id="TextAnnotation_0zc7v96">
      <text>Genera demoras en horarios de alta demanda.</text>
    </textAnnotation>
    <textAnnotation id="TextAnnotation_1m6t2dr">
      <text>El proceso depende de múltiples consultas manuales y de la intervención constante del personal de recepción.</text>
    </textAnnotation>
